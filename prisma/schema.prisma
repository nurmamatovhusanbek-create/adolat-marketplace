// Adolat — Huquqiy marketplace
// Prisma schema (SQLite for development; production-ready structure)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================================
// USERS & AUTH
// ============================================================================

enum UserRole {
  CLIENT
  ADVOCATE
  ADMIN
}

enum AccountStatus {
  PENDING
  ACTIVE
  SUSPENDED
  BANNED
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  emailVerified DateTime?
  phone         String?        @unique
  name          String
  passwordHash  String
  role          UserRole       @default(CLIENT)
  status        AccountStatus  @default(PENDING)
  avatarUrl     String?

  // Security metadata
  failedLoginAttempts Int      @default(0)
  lockedUntil         DateTime?
  lastLoginAt         DateTime?
  lastLoginIp         String?
  passwordChangedAt   DateTime @default(now())
  twoFactorSecret     String?
  twoFactorEnabled    Boolean  @default(false)

  // Relations
  advocateProfile   AdvocateProfile?
  drafts            DocumentDraft[]
  requests          LegalRequest[]
  responses         RequestResponse[]
  sentMessages      Message[]         @relation("MessageSender")
  receivedMessages Message[]         @relation("MessageReceiver")
  conversations     Conversation[]
  auditLogs         AuditLog[]
  sessions          Session[]
  notifications     Notification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([role])
  @@index([status])
}

// ============================================================================
// ADVOCATE PROFILES
// ============================================================================

model AdvocateProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  slug            String   @unique
  titleUz         String
  titleRu         String?
  bioUz           String
  bioRu           String?
  licenseNumber   String   @unique
  licenseVerified Boolean  @default(false)
  licenseDocUrl   String?

  // Specialty stored as JSON array of Specialty keys
  specialty       String
  secondarySpecs  String   @default("[]") // JSON array
  expertise       String   @default("[]") // JSON array
  languages       String   @default("[]") // JSON array

  region          String
  city            String
  experienceYears Int      @default(0)
  rating          Float    @default(0)
  reviewsCount    Int      @default(0)
  casesResolved   Int      @default(0)
  successRate     Int      @default(0)
  responseTimeHours Int    @default(24)

  consultationFee Int      @default(0) // in UZS (Tiyin)
  hourlyFee       Int      @default(0)
  verified        Boolean  @default(false)
  topRated        Boolean  @default(false)
  online          Boolean  @default(false)
  availability    String   @default("available") // available | busy | away

  tagsJson        String   @default("[]")

  education       String   @default("[]") // JSON array
  reviews         Review[]
  responses       RequestResponse[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([specialty])
  @@index([region])
  @@index([verified])
  @@index([topRated])
}

model Review {
  id           String   @id @default(cuid())
  advocateId   String
  advocate     AdvocateProfile @relation(fields: [advocateId], references: [id], onDelete: Cascade)
  userId       String
  rating       Int // 1-5
  comment      String?
  isVerified   Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@unique([advocateId, userId])
  @@index([advocateId])
}

// ============================================================================
// LEGAL DOCUMENTS & TEMPLATES
// ============================================================================

model LegalDocument {
  id            String   @id @default(cuid())
  slug          String   @unique
  titleUz       String
  titleRu       String?
  category      String
  subcategory   String?
  descriptionUz String
  descriptionRu String?
  pages         Int      @default(1)
  downloads     Int      @default(0)
  rating        Float    @default(0)
  priceUzs      Int      @default(0)
  isFree        Boolean  @default(true)
  isPopular     Boolean  @default(false)
  isNew         Boolean  @default(false)
  legalBasisUz  String?
  lastUpdated   DateTime @default(now())
  tagsJson      String   @default("[]")
  isActive      Boolean  @default(true)

  template      DocumentTemplate?
  drafts        DocumentDraft[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([isFree])
  @@index([isPopular])
}

// Document template with structured sections and placeholders.
// JSON shape validated server-side via zod.
model DocumentTemplate {
  id            String   @id @default(cuid())
  documentId    String   @unique
  document      LegalDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  // JSON: { sections: [{ id, title, fields: [{ id, label, type, required, maxLength, defaultValue, hint }] }] }
  fieldsSchema  String

  // The body content as a JSON array of paragraphs.
  // Each paragraph is either { type: "text", content: "..." } or
  // { type: "field", fieldId: "..." } which gets substituted at render time.
  bodySchema    String

  estimatedFillMinutes Int @default(10)
  version       Int      @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================================
// DRAFTS (user-saved form state — persist the exact form after download)
// ============================================================================

enum DraftStatus {
  DRAFT
  COMPLETED
  ARCHIVED
  DELETED
}

model DocumentDraft {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  documentId   String
  document     LegalDocument @relation(fields: [documentId], references: [id])

  // Encrypted JSON of fieldId -> value
  fieldValues  String   @default("{}")
  status       DraftStatus @default(DRAFT)
  version      Int      @default(1) // optimistic concurrency

  // Output artifacts
  lastDownloadedAt DateTime?
  lastDownloadFormat String? // pdf | docx
  downloadCount Int @default(0)

  // Auto-expire after 90 days
  expiresAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status])
  @@index([documentId])
  @@index([expiresAt])
}

// ============================================================================
// LEGAL REQUESTS & RESPONSES
// ============================================================================

enum RequestStatus {
  OPEN
  RESPONDING
  ACCEPTED
  CLOSED
  CANCELLED
}

model LegalRequest {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  title         String
  description   String
  category      String
  region        String
  city          String
  clientType    String   @default("individual") // individual | business
  isUrgent      Boolean  @default(false)
  status        RequestStatus @default(OPEN)

  budgetMin     Int?
  budgetMax     Int?

  viewsCount    Int      @default(0)
  responsesCount Int     @default(0)

  // Privacy: only show contact info to accepted advocate
  contactName   String?
  contactPhone  String?
  contactEmail  String?

  responses     RequestResponse[]
  expiresAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
  @@index([category, status])
  @@index([region])
}

model RequestResponse {
  id            String   @id @default(cuid())
  requestId     String
  request       LegalRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  advocateId    String
  advocate      AdvocateProfile @relation(fields: [advocateId], references: [id], onDelete: Cascade)
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  message       String
  proposedPrice Int?
  estimatedDays Int?
  isAccepted    Boolean  @default(false)
  isRejected    Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([requestId, advocateId])
  @@index([requestId])
  @@index([advocateId])
}

// ============================================================================
// MESSAGING
// ============================================================================

model Conversation {
  id            String   @id @default(cuid())
  // Sorted pair: "userA__userB" where userA.id < userB.id for uniqueness
  participantHash String @unique
  participants  User[]

  messages      Message[]
  lastMessageAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([lastMessageAt])
}

model Message {
  id            String   @id @default(cuid())
  conversationId String
  conversation  Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId      String
  sender        User     @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId    String
  receiver      User     @relation("MessageReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  content       String
  attachments   String   @default("[]") // JSON
  isRead        Boolean  @default(false)
  readAt        DateTime?

  createdAt DateTime @default(now())

  @@index([conversationId, createdAt])
  @@index([receiverId, isRead])
}

// ============================================================================
// NOTIFICATIONS
// ============================================================================

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String // request_response | message | review | system
  title     String
  body      String?
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, isRead])
}

// ============================================================================
// AUDIT LOG (security & compliance)
// ============================================================================

model AuditLog {
  id           String   @id @default(cuid())
  userId       String?
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action       String // login | logout | draft_create | doc_download | request_post | ...
  resourceType String? // document | draft | request | message | user
  resourceId   String?
  metadata     String   @default("{}") // JSON
  ipAddress    String?
  userAgent    String?
  success      Boolean  @default(true)
  createdAt    DateTime @default(now())

  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@index([resourceType, resourceId])
}

// ============================================================================
// SESSIONS (NextAuth uses next_auth_* tables by default in Prisma adapter,
// but we also keep our own for rate-limit tracking)
// ============================================================================

model Session {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionToken  String   @unique
  ipAddress     String?
  userAgent     String?
  expiresAt     DateTime
  revokedAt     DateTime?
  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([sessionToken])
}
